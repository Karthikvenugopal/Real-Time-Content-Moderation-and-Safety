KAFKA_BROKER=localhost:19092
REDIS_URL=redis://localhost:6379
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b
BLUESKY_JETSTREAM_URL=wss://jetstream2.us-east.bsky.network/subscribe
TOPIC_BLUESKY_RAW=bluesky.raw
TOPIC_BLUESKY_MODERATED=bluesky.moderated

# YouTube ingestion (optional — only needed when running youtube_producer)
YOUTUBE_API_KEY=your_google_cloud_api_key_here
YOUTUBE_SEARCH_QUERY=#Shorts
YOUTUBE_POLL_INTERVAL=30
YOUTUBE_MAX_RESULTS=10
# TOPIC_YOUTUBE_RAW=bluesky.raw  # defaults to TOPIC_BLUESKY_RAW; override to use a separate topic
